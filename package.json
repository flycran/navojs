{
  "name": "navo",
  "version": "1.0.0",
  "description": "",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "dev": "bun run --filter=\"./packages/*\" --parallel dev",
    "build": "bun run --filter=\"./packages/*\" build",
    "test": "bun run --filter=\"./packages/*\" test",
    "check": "biome check --fix && bun run --filter=\"./packages/*\" check",
    "dev:examples": "bun run --filter=\"./examples/*\" dev",
    "ci:version": "changeset version && bun update",
    "ci:publish": "bun run build && for dir in packages/*; do (cd \"$dir\" && bun publish || true); done && changeset tag"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@changesets/cli": "^2.31.0",
    "@types/bun": "^1.3.12",
    "@typescript/native-preview": "^7.0.0-dev.20260616.1",
    "typescript": "^6.0.2"
  }
}
